      <bt:LongStrings>
        <bt:String id="GetStarted.Description" DefaultValue="Open the XLerate tab to run modeling commands, or choose Show Task Pane to edit workbook settings."/>
        <bt:String id="TaskpaneButton.Tooltip" DefaultValue="Open the XLerate task pane for settings and workbook-specific XLerate preferences."/>
        <bt:String id="TracePrecBtn.Tooltip" DefaultValue="Open a keyboard-navigable dialog listing the precedents of the active cell. Arrow keys move Excel's selection live; Esc or Enter closes."/>
        <bt:String id="TraceDepBtn.Tooltip" DefaultValue="Open a keyboard-navigable dialog listing the dependents of the active cell. Arrow keys move Excel's selection live; Esc or Enter closes."/>
        <bt:String id="SwitchSignBtn.Tooltip" DefaultValue="Negate numbers or formulas in the selection. Text cells are unchanged. Ctrl+Z undoes the whole batch."/>
        <bt:String id="SmartFillBtn.Tooltip" DefaultValue="Fill the active cell's formula to the right, bounded by the values in the three rows above the active row."/>
        <bt:String id="InsertCagrBtn.Tooltip" DefaultValue="Insert a CAGR formula into the selected cell using the contiguous numeric series immediately to its left."/>
        <bt:String id="ConsistencyBtn.Tooltip" DefaultValue="Mark formulas in the selection as consistent (green) or inconsistent (red) with their horizontal neighbors. Ctrl+Z removes the marks."/>
        <bt:String id="CycleNumBtn.Tooltip" DefaultValue="Cycle the selection through the configured number-format presets."/>
        <bt:String id="CycleDateBtn.Tooltip" DefaultValue="Cycle the selection through the configured date-format presets."/>
        <bt:String id="CycleCellBtn.Tooltip" DefaultValue="Cycle the selection through cell-format presets (Normal, Inputs, Good, Bad, Important)."/>
        <bt:String id="CycleTextBtn.Tooltip" DefaultValue="Cycle the selection through text-style presets (Heading, Subheading, Sum, Normal)."/>
        <bt:String id="AutoColorBtn.Tooltip" DefaultValue="Color-code values in the selection by content type: blue for numeric inputs, green for cross-sheet references, orange for hyperlinks, black for local formulas."/>
        <bt:String id="BeautySaveBtn.Tooltip" DefaultValue="Set every visible sheet to 90% zoom, place the cursor at A1 on each, land on the first sheet, and save the workbook."/>
