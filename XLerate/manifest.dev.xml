                  <bt:Image size="16" resid="AudGrpIc.16x16"/>
                  <bt:Image size="32" resid="AudGrpIc.32x32"/>
                  <bt:Image size="80" resid="AudGrpIc.80x80"/>
                </Icon>
                <Control xsi:type="Button" id="ConsistencyBtn">
