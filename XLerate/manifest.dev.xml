<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="TaskPaneApp">
  <Id>8d69ec67-99da-4c49-8b67-01fd4cf431fd</Id>
  <Version>1.0.1.0</Version>
  <ProviderName>XLerate</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="XLerate"/>
  <Description DefaultValue="Excel add-in for financial modeling workflows, auditing, formatting cycles, and trace navigation."/>
  <IconUrl DefaultValue="https://localhost:3000/assets/icon-32.png"/>
  <HighResolutionIconUrl DefaultValue="https://localhost:3000/assets/icon-64.png"/>
  <SupportUrl DefaultValue="https://github.com/omegarhovega/XLerate/issues"/>
  <AppDomains>
    <AppDomain>https://omegarhovega.github.io</AppDomain>
  </AppDomains>
  <Hosts>
    <Host Name="Workbook"/>
  </Hosts>
  <DefaultSettings>
    <SourceLocation DefaultValue="https://localhost:3000/taskpane.html"/>
  </DefaultSettings>
  <Permissions>ReadWriteDocument</Permissions>
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="Workbook">
        <Runtimes>
          <Runtime resid="Taskpane.Url" lifetime="long"/>
        </Runtimes>
        <DesktopFormFactor>
          <GetStarted>
            <Title resid="GetStarted.Title"/>
            <Description resid="GetStarted.Description"/>
            <LearnMoreUrl resid="GetStarted.LearnMoreUrl"/>
          </GetStarted>
          <FunctionFile resid="Taskpane.Url"/>
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <CustomTab id="XLerateTab">
              <Group id="FormulasGroup">
                <Label resid="FormulasGroup.Label"/>
                <Icon>
                  <bt:Image size="16" resid="FmlGrpIc.16x16"/>
                  <bt:Image size="32" resid="FmlGrpIc.32x32"/>
                  <bt:Image size="80" resid="FmlGrpIc.80x80"/>
                </Icon>
                <Control xsi:type="Button" id="TracePrecedentsDialogButton">
                  <Label resid="TracePrecBtn.Label"/>
                  <Supertip>
                    <Title resid="TracePrecBtn.Label"/>
                    <Description resid="TracePrecBtn.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="TracePrecIc.16x16"/>
                    <bt:Image size="32" resid="TracePrecIc.32x32"/>
                    <bt:Image size="80" resid="TracePrecIc.80x80"/>
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>openTracePrecedentsDialog</FunctionName>
                  </Action>
                </Control>
                <Control xsi:type="Button" id="TraceDependentsDialogButton">
                  <Label resid="TraceDepBtn.Label"/>
                  <Supertip>
                    <Title resid="TraceDepBtn.Label"/>
                    <Description resid="TraceDepBtn.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="TraceDepIc.16x16"/>
                    <bt:Image size="32" resid="TraceDepIc.32x32"/>
                    <bt:Image size="80" resid="TraceDepIc.80x80"/>
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>openTraceDependentsDialog</FunctionName>
                  </Action>
                </Control>
                <Control xsi:type="Button" id="SwitchSignBtn">
                  <Label resid="SwitchSignBtn.Label"/>
                  <Supertip>
                    <Title resid="SwitchSignBtn.Label"/>
                    <Description resid="SwitchSignBtn.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="SwSignIc.16x16"/>
                    <bt:Image size="32" resid="SwSignIc.32x32"/>
                    <bt:Image size="80" resid="SwSignIc.80x80"/>
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>runSwitchSign</FunctionName>
                  </Action>
                </Control>
                <Control xsi:type="Button" id="SmartFillBtn">
                  <Label resid="SmartFillBtn.Label"/>
                  <Supertip>
                    <Title resid="SmartFillBtn.Label"/>
                    <Description resid="SmartFillBtn.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="SmFillIc.16x16"/>
                    <bt:Image size="32" resid="SmFillIc.32x32"/>
                    <bt:Image size="80" resid="SmFillIc.80x80"/>
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>runSmartFillRight</FunctionName>
                  </Action>
                </Control>
                <Control xsi:type="Button" id="InsertCagrBtn">
                  <Label resid="InsertCagrBtn.Label"/>
                  <Supertip>
                    <Title resid="InsertCagrBtn.Label"/>
                    <Description resid="InsertCagrBtn.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>runInsertCagr</FunctionName>
                  </Action>
                </Control>
              </Group>
              <Group id="AuditingGroup">
                <Label resid="AuditingGroup.Label"/>
