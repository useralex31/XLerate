                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>runCycleDateFormat</FunctionName>
                  </Action>
                </Control>
                <Control xsi:type="Button" id="CycleCellBtn">
                  <Label resid="CycleCellBtn.Label"/>
