                    <Title resid="CycleDateBtn.Label"/>
                    <Description resid="CycleDateBtn.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="CycDateIc.16x16"/>
                    <bt:Image size="32" resid="CycDateIc.32x32"/>
                    <bt:Image size="80" resid="CycDateIc.80x80"/>
