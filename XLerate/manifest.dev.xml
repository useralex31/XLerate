                    <Description resid="ConsistencyBtn.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="ConsIc.16x16"/>
                    <bt:Image size="32" resid="ConsIc.32x32"/>
                    <bt:Image size="80" resid="ConsIc.80x80"/>
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>runFormulaConsistency</FunctionName>
                  </Action>
                </Control>
              </Group>
              <Group id="FormattingGroup">
