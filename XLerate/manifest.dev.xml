                    <Title resid="CycleCellBtn.Label"/>
                    <Description resid="CycleCellBtn.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="CycCellIc.16x16"/>
                    <bt:Image size="32" resid="CycCellIc.32x32"/>
                    <bt:Image size="80" resid="CycCellIc.80x80"/>
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>runCycleCellFormat</FunctionName>
                  </Action>
                </Control>
                <Control xsi:type="Button" id="CycleTextBtn">
                  <Label resid="CycleTextBtn.Label"/>
                  <Supertip>
                    <Title resid="CycleTextBtn.Label"/>
                    <Description resid="CycleTextBtn.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="CycTextIc.16x16"/>
                    <bt:Image size="32" resid="CycTextIc.32x32"/>
                    <bt:Image size="80" resid="CycTextIc.80x80"/>
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>runCycleTextStyle</FunctionName>
                  </Action>
                </Control>
                <Control xsi:type="Button" id="AutoColorBtn">
                  <Label resid="AutoColorBtn.Label"/>
                  <Supertip>
                    <Title resid="AutoColorBtn.Label"/>
                    <Description resid="AutoColorBtn.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="AutoClrIc.16x16"/>
                    <bt:Image size="32" resid="AutoClrIc.32x32"/>
                    <bt:Image size="80" resid="AutoClrIc.80x80"/>
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>runAutoColor</FunctionName>
                  </Action>
                </Control>
                <Control xsi:type="Button" id="BeautySaveBtn">
                  <Label resid="BeautySaveBtn.Label"/>
                  <Supertip>
                    <Title resid="BeautySaveBtn.Label"/>
                    <Description resid="BeautySaveBtn.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>runBeautySave</FunctionName>
                  </Action>
                </Control>
              </Group>
              <Group id="SettingsGroup">
                <Label resid="SettingsGroup.Label"/>
                <Icon>
                  <bt:Image size="16" resid="SetGrpIc.16x16"/>
                  <bt:Image size="32" resid="SetGrpIc.32x32"/>
                  <bt:Image size="80" resid="SetGrpIc.80x80"/>
                </Icon>
                <Control xsi:type="Button" id="TaskpaneButton">
                  <Label resid="TaskpaneButton.Label"/>
                  <Supertip>
                    <Title resid="TaskpaneButton.Label"/>
                    <Description resid="TaskpaneButton.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="PaneIc.16x16"/>
                    <bt:Image size="32" resid="PaneIc.32x32"/>
                    <bt:Image size="80" resid="PaneIc.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>ButtonId1</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url"/>
                  </Action>
                </Control>
              </Group>
              <Label resid="XLerateTab.Label"/>
            </CustomTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
